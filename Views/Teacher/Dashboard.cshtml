@model List<AttendanceApp.Controllers.AttendanceSummary>

<div class="container mt-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Teacher Dashboard</h3>
        <form asp-action="Logout" asp-controller="Teacher" method="post">
            <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
        </form>
    </div>

    <!-- Create Class Button -->
    <div class="text-center mb-4">
        <a asp-controller="Teacher" asp-action="CreateClass" class="btn btn-primary btn-lg">
            + Create New Class
        </a>
    </div>

    <!-- Your Classes -->
    <h4>Your Classes</h4>
    <div class="row mb-4">
        @foreach (var cls in ViewBag.Classes)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <h5 class="card-title">@cls.ClassName</h5>
                        <div class="d-flex justify-content-between mt-3">
                            <a asp-action="EditClass" asp-route-id="@cls.ClassId" class="btn btn-warning btn-sm">
                                Edit
                            </a>
                            <a asp-action="DeleteClass" asp-route-id="@cls.ClassId" class="btn btn-danger btn-sm"
                               onclick="return confirm('Are you sure you want to delete this class?');">
                                Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Attendance Summary -->
    <h4>Attendance Summary</h4>
    <div class="table-responsive">
        <table class="table table-bordered table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Class Name</th>
                    <th>Date</th>
                    <th>Total Students</th>
                    <th>Excel</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ClassName</td>
                        <td>@item.Date.ToString("yyyy-MM-dd")</td>
                        <td>@item.Total</td>
                        <td>
                            <a class="btn btn-success btn-sm"
                               href="/Teacher/DownloadExcel?classId=@item.ClassId&date=@item.Date.ToString("yyyy-MM-dd")">
                                Download
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>